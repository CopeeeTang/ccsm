/* ── Claude Brand Theme ─────────────────────────────────────────────────────
 * Primary:    #d97757 (Claude Orange — warm terracotta)
 * Background: #141413 (deep warm black)
 * Panel BG:   #1e1d1c (elevated surface)
 * Text:       #e8e6dc (warm parchment white)
 * Secondary:  #b0aea5 (muted stone)
 * Muted:      #78716c (stone-500)
 * Border:     #3a3835 (subtle separator)
 * Status:     #788c5d (muted green), #6a9bcc (muted blue), #a78bfa (lavender)
 * ──────────────────────────────────────────────────────────────────────────── */

/* ── Global ──────────────────────────────────────────────────────────────── */

Screen {
    background: #141413;
    color: #e8e6dc;
}

/* ── Dual-Panel Layout (Worktree + Sessions) ───────────────────────────── */

#main-container {
    layout: horizontal;
    height: 1fr;
    width: 100%;
}

/* ── Left Panel: Worktree Tree ──────────────────────────────────────────── */

#worktree-panel {
    width: 20%;
    min-width: 18;
    background: #1e1d1c;
    border-right: solid #3a3835;
    padding: 0;
}

#worktree-panel .panel-title {
    dock: top;
    height: 3;
    content-align: center middle;
    background: #141413;
    color: #78716c;
    text-style: bold;
    border-bottom: solid #3a3835;
    padding: 0 1;
}

#worktree-tree {
    background: #1e1d1c;
    padding: 0 1;
    scrollbar-size: 1 1;
}

#worktree-tree > .tree--label {
    color: #e8e6dc;
}

#worktree-tree > .tree--cursor {
    background: #d97757 20%;
    color: #d97757;
    text-style: bold;
}

#worktree-tree > .tree--highlight {
    background: #d97757 10%;
}

/* ── Right Panel: Session List (80% width) ────────────────────────────── */

#session-panel {
    width: 80%;
    background: #1e1d1c;
    padding: 0;
}

#session-panel .panel-title {
    dock: top;
    height: 3;
    content-align: center middle;
    background: #141413;
    color: #78716c;
    text-style: bold;
    border-bottom: solid #3a3835;
    padding: 0 1;
}

#session-list-container {
    background: #1e1d1c;
    padding: 0;
    scrollbar-size: 1 1;
}

/* ── Session Card (compose-based flex layout) ─────────────────────────── */

.session-card {
    layout: horizontal;
    height: auto;
    max-height: 5;
    padding: 0 1;
    margin: 0;
    background: #1e1d1c;
    border-bottom: solid #3a3835;
}

.session-card:hover {
    background: #3a3835 40%;
}

.session-card.-selected {
    background: #d97757 12%;
    border-left: tall #d97757;
}

/* Spine gutter: fixed-width time + graph connector */
.card-spine {
    width: 8;
    min-width: 8;
    height: auto;
    padding: 0;
    content-align: right top;
    color: #78716c;
}

/* Card body: flex vertical, takes remaining width */
.card-body {
    width: 1fr;
    height: auto;
    padding: 0 0 0 1;
}

/* Title row: horizontal flex, title fills remaining space */
.card-row-title {
    layout: horizontal;
    height: 1;
    width: 100%;
}

.card-title {
    width: 1fr;
    height: 1;
    color: #e8e6dc;
    text-style: bold;
    overflow: hidden;
}

.card-tag {
    width: auto;
    min-width: 8;
    height: 1;
    padding: 0 1;
    text-style: bold;
}

.tag-active { color: #788c5d; }
.tag-background { color: #6a9bcc; }
.tag-idea { color: #a78bfa; }
.tag-done { color: #78716c; }
.tag-noise { color: #3a3835; }

.card-badge {
    width: auto;
    height: 1;
    padding: 0 1;
}

.lineage-fork { color: #6a9bcc; }
.lineage-compact { color: #a78bfa; }
.lineage-dup { color: #e87b7b; }

.card-time {
    width: auto;
    min-width: 10;
    height: 1;
    content-align: right middle;
    color: #78716c;
}

/* Intent row: horizontal flex, intent fills remaining space */
.card-row-intent {
    layout: horizontal;
    height: 1;
    width: 100%;
}

.card-intent {
    width: 1fr;
    height: 1;
    color: #b0aea5;
    overflow: hidden;
}

.card-msgcount {
    width: auto;
    min-width: 6;
    height: 1;
    content-align: right middle;
    color: #78716c;
}

/* ── Status badges ─────────────────────────────────────────────────────── */

.badge-active {
    color: #788c5d;
    text-style: bold;
}

.badge-background {
    color: #6a9bcc;
}

.badge-idea {
    color: #a78bfa;
}

.badge-done {
    color: #78716c;
}

.badge-noise {
    color: #3a3835;
}

/* ── Priority badges ────────────────────────────────────────────────────── */

.priority-focus {
    color: #d97757;
    text-style: bold;
}

.priority-watch {
    color: #d4b86a;
}

.priority-park {
    color: #78716c;
}

.priority-hide {
    color: #3a3835;
}

/* ── Status Group Headers ───────────────────────────────────────────────── */

/* ── Date Divider ──────────────────────────────────────────────────────── */

.date-divider {
    height: 1;
    padding: 0 1;
    background: #141413;
    color: #d97757;
    text-style: bold;
}

.status-group-header {
    height: 1;
    padding: 0 1;
    background: #141413;
    color: #b0aea5;
    text-style: bold;
    border-bottom: solid #3a3835;
}

/* ── Drawer Overlay (centered modal) ──────────────────────────────────── */

SessionDetailDrawer {
    align: center middle;
}

#drawer-panel {
    width: 70%;
    height: 90%;
    background: #121110;
    border: solid #d97757;
    padding: 0;
}

.drawer-title {
    dock: top;
    height: 3;
    content-align: center middle;
    background: #141413;
    color: #78716c;
    text-style: bold;
    border-bottom: solid #3a3835;
    padding: 0 1;
}

/* ── Detail Content (inside Drawer) ────────────────────────────────────── */

#detail-content {
    background: #121110;
    padding: 1 2;
    scrollbar-size: 1 1;
    height: 1fr;
}

.detail-section {
    margin-bottom: 2;
    padding: 0;
    height: auto;
}

.detail-section-title {
    color: #b0aea5;
    text-style: bold;
    margin-bottom: 0;
    padding: 0;
    height: auto;
}

.detail-section-body {
    color: #e8e6dc;
    padding: 0 0 0 1;
    height: auto;
}

.detail-reply-label {
    color: #78716c;
    padding: 0;
    height: auto;
}

.detail-reply-content {
    padding: 1 2;
    margin: 0;
    background: #141413;
    color: #e8e6dc;
    height: auto;
    max-height: 30;
    overflow-y: auto;
}

/* ── Markdown Rendering Quality ──────────────────────────────────────── */

.detail-reply-content MarkdownFence {
    background: #0d0c0b;
    margin: 1 0;
    padding: 0;
}

.detail-reply-content MarkdownFence > Label {
    padding: 1 2;
    color: #d4d4d4;
}

.detail-reply-content MarkdownH1 {
    color: #d97757;
    text-style: bold;
    background: transparent;
    margin: 1 0;
}

.detail-reply-content MarkdownH2 {
    color: #e8e6dc;
    text-style: bold;
    background: transparent;
    margin: 1 0;
}

.detail-reply-content MarkdownH3 {
    color: #b0aea5;
    text-style: bold;
    background: transparent;
    margin: 1 0;
}

.detail-reply-content MarkdownParagraph {
    margin: 0 0 1 0;
}

.detail-reply-content MarkdownBulletList {
    margin: 0 0 1 0;
    padding: 0 0;
}

.detail-reply-content MarkdownOrderedList {
    margin: 0 0 1 0;
    padding: 0 0;
}

.detail-reply-content MarkdownBlockQuote {
    background: #1e1d1c;
    border-left: outer #d97757 40%;
    margin: 1 0;
    padding: 0 1;
}

.detail-reply-content MarkdownBlock > .code_inline {
    background: #d97757 12%;
    color: #e8b96a;
}

/* ── Session Identity Card (panel border) ───────────────────────── */

.det-session-card {
    margin: 0 1 1 1;
    padding: 1;
    height: auto;
    border: panel #3a3835;
    background: #1e1d1c;
}

/* ── AI Digest Section (visually prominent, always expanded) ─────── */

.det-digest-section {
    margin: 0 1 2 1;
    padding: 1;
    height: auto;
    border: panel #6a9bcc 40%;
    background: #6a9bcc 4%;
}

/* ── Breakpoint Box (panel border, visually prominent) ────────────── */

.det-breakpoint-section {
    margin: 1 1 2 1;
    padding: 0;
    height: auto;
    border: panel #d97757 40%;
    background: #d97757 6%;
}

.detail-breakpoint-body {
    color: #e8e6dc;
    padding: 1 2;
    margin: 0;
    height: auto;
}

/* ── Breakpoint Badge ─────────────────────────────────────────────────── */

.det-breakpoint-badge {
    background: #d97757;
    color: #141413;
    text-style: bold;
    padding: 0 1;
    height: auto;
    width: auto;
    margin: 0;
}

/* ── Milestone Stepper ────────────────────────────────────────────────── */

.det-milestones {
    border-left: solid #3a3835;
    padding: 0 0 0 1;
    margin: 0 0 0 2;
    height: auto;
}

.det-ms-item {
    height: auto;
    padding: 0 0 0 0;
    margin: 0 0 1 0;
}

.det-ms-active {
    height: auto;
    padding: 0 1;
    margin: 0 0 1 0;
    background: #d97757 10%;
    border-left: solid #d97757;
}

.det-ms-sub {
    height: auto;
    padding: 0;
    margin: 0 0 0 2;
    color: #b0aea5;
}

/* ── Summary Intent (block-quote style) ───────────────────────────────── */

.det-summary-intent {
    border-left: solid #d97757 40%;
    padding: 0 1;
    margin: 0 2;
    color: #b0aea5;
    text-style: italic;
    height: auto;
}

/* ── Chat Bubble (Last Exchange) ──────────────────────────────────────── */

.det-chat-row {
    height: auto;
    margin: 0 0 1 0;
}

.det-chat-avatar {
    width: 5;
    min-width: 5;
    height: 1;
    background: #a78bfa 30%;
    color: #e8e6dc;
    text-style: bold;
    content-align: center middle;
    padding: 0;
}

.det-chat-avatar-user {
    background: #788c5d 30%;
}

.det-chat-msg {
    border: solid #3a3835;
    padding: 1 2;
    margin: 0 0 0 1;
    background: #141413;
    height: auto;
    max-height: 20;
    overflow-y: auto;
}

/* ── Focus Indicators ───────────────────────────────────────────────────── */

#worktree-panel:focus-within {
    border-right: solid #e8e6dc;
}

/* ── Footer ──────────────────────────────────────────────────────────────── */

#footer-bar {
    dock: bottom;
    height: 1;
    background: #141413;
    color: #78716c;
    padding: 0 1;
}

.footer-key {
    color: #d97757;
    text-style: bold;
}

.footer-label {
    color: #78716c;
}

/* ── Header ──────────────────────────────────────────────────────────────── */

#header-bar {
    dock: top;
    height: 1;
    background: #141413;
    color: #d97757;
    text-style: bold;
    padding: 0 1;
}

/* ── Loading Indicator ──────────────────────────────────────────────────── */

.loading-indicator {
    content-align: center middle;
    color: #78716c;
    text-style: italic;
    height: 100%;
    width: 100%;
}

/* ── Empty State ─────────────────────────────────────────────────────────── */

.empty-state {
    content-align: center middle;
    color: #78716c;
    text-style: italic;
    padding: 2;
    height: auto;
}

/* ── Status Tab Bar / Filter Bar ─────────────────────────────────────────── */

.status-tab-bar {
    height: 2;
    padding: 0 1;
    background: #141413;
    color: #b0aea5;
    text-style: bold;
    border-bottom: solid #3a3835;
    dock: top;
}

/* ── AI Summary Section ─────────────────────────────────────────────────── */

.ai-summary-section {
    margin-bottom: 1;
    padding: 0;
    height: auto;
}

.ai-summary-section .detail-section-body {
    padding: 0 0 0 1;
    height: auto;
}

/* ── Swimlane in Session Panel ──────────────────────────────────────────── */

#session-list-container Swimlane {
    padding: 1 1;
    height: auto;
}

/* ── Collapsible Sections (WHAT WAS DONE, LAST EXCHANGE) ───────────────── */

#detail-content Collapsible {
    background: #121110;
    border: none;
    padding: 0;
    margin-bottom: 1;
    height: auto;
}

#detail-content Collapsible > CollapsibleTitle {
    color: #b0aea5;
    background: #141413;
    padding: 0 1;
    text-style: bold;
    height: auto;
}

#detail-content Collapsible > CollapsibleTitle:hover {
    background: #3a3835 40%;
    color: #e8e6dc;
}

#detail-content Collapsible > Contents {
    padding: 0 0 0 1;
    height: auto;
}

/* ── Search Input ───────────────────────────────────────────────────────── */

.search-input {
    height: 3;
    margin: 0;
    padding: 0 1;
    background: #141413;
    color: #e8e6dc;
    border: solid #d97757 40%;
}

.search-input.-hidden {
    display: none;
}

.search-input:focus {
    border: solid #d97757;
}

/* ── Light Theme Overrides ── */
.-light-theme Screen { background: #faf9f5; color: #141413; }
.-light-theme #worktree-panel { background: #ffffff; border-right: solid #e6e4df; }
.-light-theme #worktree-panel .panel-title { background: #faf9f5; color: #5e5c54; border-bottom: solid #e6e4df; }
.-light-theme #worktree-tree { background: #ffffff; }
.-light-theme #worktree-tree > .tree--label { color: #141413; }
.-light-theme #worktree-panel:focus-within { border-right: solid #141413; }

.-light-theme #session-panel { background: #ffffff; }
.-light-theme #session-panel .panel-title { background: #faf9f5; color: #5e5c54; border-bottom: solid #e6e4df; }
.-light-theme #session-list-container { background: #ffffff; }
.-light-theme .search-input { background: #ffffff; color: #141413; border: solid #e6e4df; }
.-light-theme .search-input:focus { border: solid #c97040; }

.-light-theme .session-card { background: #ffffff; border-bottom: solid #e6e4df; }
.-light-theme .session-card:hover { background: #f3f2eb; }
.-light-theme .card-title { color: #141413; }

.-light-theme .status-tab-bar { background: #faf9f5; border-bottom: solid #e6e4df; }

.-light-theme .date-divider { background: #faf9f5; color: #c97040; }
.-light-theme .status-group-header { background: #faf9f5; color: #5e5c54; border-bottom: solid #e6e4df; }

.-light-theme .lineage-group { background: #ffffff; }
.-light-theme .lineage-expand-bar { background: #faf9f5; color: #5e5c54; }
.-light-theme .lineage-expand-bar:hover { color: #c97040; background: rgba(217,119,87, 0.08); }

.-light-theme #drawer-panel { background: #fdfdfc; border: solid #c97040; }
.-light-theme .drawer-title { background: #faf9f5; color: #5e5c54; border-bottom: solid #e6e4df; }
.-light-theme #detail-content { background: #fdfdfc; }

.-light-theme .detail-section-body { color: #141413; }
.-light-theme .detail-reply-content { background: #faf9f5; color: #141413; border: solid #e6e4df; }
.-light-theme .detail-reply-content MarkdownFence { background: #ebe8e1; }
.-light-theme .detail-reply-content MarkdownFence > Label { color: #5e5c54; }
.-light-theme .detail-reply-content MarkdownBlockQuote { background: #f3f2eb; border-left: outer #c97040 40%; }
.-light-theme .detail-reply-content MarkdownBlock > .code_inline { background: rgba(217,119,87, 0.12); color: #c97040; }

.-light-theme .det-breakpoint-section { background: rgba(217,119,87, 0.08); }
.-light-theme .det-breakpoint-badge { background: #c97040; color: #ffffff; }
.-light-theme .detail-breakpoint-body { color: #141413; }
.-light-theme .det-session-card { background: #ffffff; border: panel #e6e4df; }
.-light-theme .det-digest-section { background: rgba(106,155,204, 0.06); border: panel #6a9bcc 40%; }

.-light-theme #detail-content Collapsible { background: #faf9f5; }
.-light-theme #detail-content Collapsible > CollapsibleTitle { background: #f3f2eb; color: #5e5c54; }
.-light-theme #detail-content Collapsible > CollapsibleTitle:hover { background: #ebe8e1; color: #141413; }
.-light-theme .det-chat-msg { background: #faf9f5; border: round #e6e4df; }
.-light-theme .det-chat-avatar { color: #141413; }
.-light-theme .det-chat-avatar-user { color: #141413; }

.-light-theme #header-bar { background: #faf9f5; color: #c97040; }
.-light-theme #footer-bar { background: #faf9f5; color: #5e5c54; }
.-light-theme .footer-key { color: #c97040; }

/* Light theme scrollbars */
.-light-theme Scrollbar { background: #ffffff; }
.-light-theme Scrollbar > .scrollbar--slider { background: #d5d3cc; }
.-light-theme Scrollbar > .scrollbar--thumb { background: #d5d3cc; }
.-light-theme Scrollbar > .scrollbar--slider:hover { background: #b0aea5; }
.-light-theme Scrollbar > .scrollbar--thumb:hover { background: #b0aea5; }

/* Light theme card spine + intents */
.-light-theme .card-spine { color: #b0aea5; }
.-light-theme .card-spine-graph { color: #c97040; }

.-light-theme .card-intent { color: #5e5c54; }
.-light-theme .card-time { color: #5e5c54; }
.-light-theme .card-msgcount { color: #5e5c54; }


/* ── Fork Universe Block (legacy class, replaced by fork-branch-block) ── */
.fork-universe {
    background: #18161a;
    border: dashed rgba(168, 85, 247, 0.4);
    margin: 1 2 2 4;
    padding: 1 0;
    height: auto;
}

/* Fork universe: flatten history steps inside (no staircase in fork) */
.fork-universe .history-step-1,
.fork-universe .history-step-2,
.fork-universe .history-step-3 {
    margin-left: 0;
    opacity: 0.8;
}

/* ── Lineage Group Container ── */
.lineage-group {
    margin: 0 0 1 0;
    padding: 0;
    height: auto;
}

/* ── Fork Branch Block (isolated purple space for fork sessions) ── */
.fork-branch-block {
    background: #18161a;
    border: dashed rgba(168, 85, 247, 0.35);
    margin: 1 1 1 4;
    padding: 1 1;
    height: auto;
}

.fork-branch-block .session-card {
    border-left: tall #a855f7;
    background: #141413;
}

/* Fork card (flat, inline — used when fork not in container) */
.fork-card {
    margin-left: 4;
}

.fork-card .card-body {
    border-left: tall #a855f7;
}

.fork-anchor-label {
    height: 1;
    padding: 0 1;
    margin-left: 4;
    color: #a855f7;
    text-style: bold;
    margin-bottom: 0;
}

/* ── Fork Point Separator ── */
.fork-point-separator {
    height: 1;
    padding: 0 1;
    color: #a855f7;
    margin: 1 0 0 0;
}

/* ── Compact Card (blue-tinted left border) ── */
.compact-card .card-body {
    border-left: tall #6a9bcc;
}

/* ── Duplicate Card (dimmed display) ── */
.duplicate-card {
    opacity: 0.65;
}

.duplicate-card .card-body {
    border-left: tall #e87b7b;
}

.-light-theme .fork-universe {
    background: #fbf0ff;
    border: dashed #c084fc;
}

.-light-theme .fork-branch-block {
    background: #faf5ff;
    border: dashed #c084fc;
}

.-light-theme .fork-card .card-body { border-left: tall #9333ea; }
.-light-theme .fork-anchor-label { color: #9333ea; }

.-light-theme .fork-anchor-label { color: #9333ea; }
.-light-theme .fork-point-separator { color: #9333ea; }
.-light-theme .compact-card .card-body { border-left: tall #3b82f6; }
.-light-theme .duplicate-card .card-body { border-left: tall #ef4444; }

/* ── Stepped Compacts (Staircase indent for history, NO negative margin) ── */
.history-step-1 {
    margin-left: 3;
    margin-top: 0;
    opacity: 0.85;
}
.history-step-2 {
    margin-left: 5;
    margin-top: 0;
    opacity: 0.7;
}
.history-step-3 {
    margin-left: 7;
    margin-top: 0;
    opacity: 0.6;
}

/* Hide intent for deep history for density */
.history-step-2 .card-row-intent,
.history-step-3 .card-row-intent {
    display: none;
}

/* Fork point badge */
.badge-fork-point {
    background: #4c1d95;
    color: #f5f3ff;
    text-style: bold;
    padding: 0 1;
    margin-right: 1;
}
.-light-theme .badge-fork-point {
    background: #c084fc;
    color: #ffffff;
}

.card-spine-graph {
    display: none;
}
